# Copie para infra/backup/restic.env e restrinja as permissões com chmod 600.
# Para Google Drive, configure primeiro um remote chamado "gdrive" no rclone.
RESTIC_REPOSITORY=rclone:gdrive:renda-com-carro
RESTIC_PASSWORD=SUBSTITUA_POR_UMA_SENHA_LONGA_E_UNICA
RESTIC_AUTO_INIT=false
RESTIC_HOST=renda-com-carro-pi
